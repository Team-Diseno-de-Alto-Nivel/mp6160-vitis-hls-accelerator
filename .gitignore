# Build artifacts
build/
*.o
*.a
*.so
*.out

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake
_deps/

# Raw / binary images: regenerated by the pipeline, not tracked. The input
# image.raw is produced from the tracked images/input/image.jpg by
# scripts/prepare_input.py; the outputs are produced by the model / gem5 / HLS.
*.raw
*.bin

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
*.egg-info/

# macOS
.DS_Store
.AppleDouble

# Editor
.vscode/*
!.vscode/c_cpp_properties.json
*.swp
*~

# Vitis HLS — everything under here is generated by `vitis_hls -f run_hls.tcl`.
# The reports are the *source* of the numbers in README.md "Results", not a
# deliverable themselves (docs/Enunciado.md asks for the results explained in the
# README), so they are not tracked.
src/hls/scripts/grayscale_accel_prj/
*.rpt
vitis_hls*.log
vitis-run*.log
.Xil/

# gem5's scons output, mounted over /opt/gem5/build so rebuilds are incremental.
# Used by results-gem5.yml (actions/cache) and by the local dev-container loop.
.gem5-build/

Import("*")

SimObject("Accelerator.py", sim_objects=["GrayscaleAccelerator"])

Source("accelerator_wrapper.cc")

# The accelerator model itself is declared by ../model/SConscript, not here: a
# Source() path containing ".." escapes the variant-dir mapping gem5 registers
# for this directory and then fails to resolve. See that file for the details.
#
# No CPPPATH is set up either. Every cross-directory include in this module and
# in ../model is written relative to the file that issues it, which is what makes
# them resolve everywhere — including in the generated param_GrayscaleAccelerator.cc,
# which gem5 compiles in an environment that would not inherit a CPPPATH set here.
# A search-path include is exactly how the src/ restructure broke this build:
# it compiled accelerator_wrapper.cc fine and only failed on the generated file.

Import("*")

SimObject("Accelerator.py", sim_objects=["GrayscaleAccelerator"])

Source("accelerator_wrapper.cc")

# The accelerator model is not copied here — this is the exact same translation
# unit the standalone sim in ../../systemc-model compiles, which is what keeps
# the two tracks behaviourally identical.
Source("../../systemc-model/src/accelerator/accelerator.cpp")

# accelerator.h resolves "memory_map.h" from ../../common, and accelerator.cpp
# resolves "../utils/conversion.h" relative to itself.
env.Append(
    CPPPATH=[
        Dir("../../common"),
        Dir("../../systemc-model/src"),
    ]
)
